   "execution_count": 10,
   "id": "1d808635",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-31T13:20:43.671476Z",
     "iopub.status.busy": "2026-05-31T13:20:43.670928Z",
     "iopub.status.idle": "2026-05-31T13:20:43.694695Z",
     "shell.execute_reply": "2026-05-31T13:20:43.693754Z"
    },
    "papermill": {
     "duration": 0.031726,
     "end_time": "2026-05-31T13:20:43.696636+00:00",

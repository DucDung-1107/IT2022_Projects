    "# =============================================================================\n",
    "# PART 1 — LOAD\n",
    "# =============================================================================\n",
    "\n",
    "def load_daily(path, high_col, low_col, vol_col, close_col, date_col='Date'):\n",
    "    df = pd.read_csv(path, parse_dates=[date_col])\n",
    "    df = df.sort_values(date_col).reset_index(drop=True)\n",
    "    df[df.columns[1:]] = df[df.columns[1:]].ffill().bfill()\n",
    "    return pd.DataFrame({\n",
    "        'date'  : df[date_col],\n",
    "        'close' : df[close_col].astype(float),\n",
    "        'high'  : df[high_col].astype(float),\n",
    "        'low'   : df[low_col].astype(float),\n",
    "        'volume': df[vol_col].astype(float),\n",
    "    })"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "a33530a7",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-31T13:20:43.516461Z",
     "iopub.status.busy": "2026-05-31T13:20:43.516036Z",
     "iopub.status.idle": "2026-05-31T13:20:43.523852Z",
     "shell.execute_reply": "2026-05-31T13:20:43.522787Z"
    },
